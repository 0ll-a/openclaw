{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "OPENCLAW_EXTENSIONS": "",
      "OPENCLAW_BUNDLED_PLUGIN_DIR": "extensions",
      "OPENCLAW_DOCKER_BUILD_SKIP_DTS": "1"
    }
  },
  "deploy": {
    "startCommand": "node dist/index.js gateway --allow-unconfigured --port $PORT --bind 0.0.0.0",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "healthCheck": {
    "httpPath": "/healthz",
    "httpPort": 3000,
    "initialDelaySeconds": 15,
    "intervalSeconds": 30,
    "timeoutSeconds": 10
  },
  "volumes": [
    {
      "name": "openclaw-data",
      "mountPath": "/data"
    }
  ]
}
